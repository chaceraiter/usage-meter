# usage-meter environment configuration
#
# This file documents the environment variables the app recognizes.
# Copy to `.env` and fill in values for local development.
# `.env` is gitignored — never commit real values.
#
# NOTE: Session cookies are NOT configured here. They are captured through
# the app's settings UI and stored in the macOS Keychain. See SECURITY.md.

# Polling interval in seconds (default: 60)
USAGE_METER_POLL_INTERVAL=60

# Log level: error | warn | info | debug | trace (default: info)
USAGE_METER_LOG_LEVEL=info
